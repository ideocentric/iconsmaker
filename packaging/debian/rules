#!/usr/bin/make -f
# iconsmaker Debian packaging — offline Rust build.
#
# Launchpad/Debian builders have NO network, so crate dependencies must be
# vendored into ./vendor before building the source package (see README.md).
# CARGO_HOME is redirected to a build-local dir with a config that points cargo
# at the vendored sources.

export CARGO_HOME := $(CURDIR)/debian/cargo
export CARGO_NET_OFFLINE := true

# Ubuntu's default rustc lags the release (noble ships 1.75). Edition 2024 needs
# >= 1.85, and our dependency tree needs more still (image 0.25.x requires
# 1.88). We Build-Depend on the co-installable versioned toolchain
# (cargo-1.89/rustc-1.89, present for amd64+arm64 in noble-updates) and put its
# real `cargo`/`rustc` first on PATH so the plain invocations below use 1.89.
export PATH := /usr/lib/rust-1.89/bin:$(PATH)

%:
	dh $@

override_dh_auto_configure:
	mkdir -p $(CARGO_HOME)
	printf '[source.crates-io]\nreplace-with = "vendored-sources"\n\n[source.vendored-sources]\ndirectory = "$(CURDIR)/vendor"\n' > $(CARGO_HOME)/config.toml

override_dh_auto_build:
	# dpkg-source's 3.0 (quilt) round-trip drops vendor/*/Cargo.toml.orig, but the
	# vendored .cargo-checksum.json files still list them, so cargo's offline
	# checksum verification aborts ("failed to calculate checksum of ...
	# Cargo.toml.orig"). Blank the per-file checksum maps (the crate-level
	# "package" hash is kept) so cargo skips the missing-file check.
	find vendor -name .cargo-checksum.json -print0 | xargs -0 sed -i 's/"files":{[^}]*}/"files":{}/'
	cargo build --release --offline --locked

override_dh_auto_test:
	./target/release/iconsmaker --version

override_dh_auto_install:
	install -Dm0755 target/release/iconsmaker debian/iconsmaker/usr/bin/iconsmaker
	./target/release/iconsmaker --print-man-page > debian/iconsmaker.1
	install -Dm0644 debian/iconsmaker.1 debian/iconsmaker/usr/share/man/man1/iconsmaker.1

override_dh_auto_clean:
	rm -rf target $(CARGO_HOME) debian/iconsmaker.1

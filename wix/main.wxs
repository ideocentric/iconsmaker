<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX v3 source for the iconsmaker Windows MSI, built with cargo-wix.
  Build a release binary, then run "cargo wix" to produce
  target/wix/iconsmaker-<version>-x86_64.msi.

  cargo-wix supplies the preprocessor variables $(var.Version) and
  $(var.CargoTargetBinDir). The HTML help (iconsmaker.html) is expected at
  target\assets\iconsmaker.html; the release workflow generates it from the man
  page before invoking cargo-wix.

  Installs per-machine to "Program Files\iconsmaker", adds that folder to the
  system PATH, and bundles the license plus HTML documentation.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="iconsmaker"
        UpgradeCode="6F3A1C24-9E7B-4B2E-A5D1-2C0F8B6E4A11"
        Manufacturer="Matt Comeione"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package
            Id="*"
            Keywords="Installer"
            Description="iconsmaker — generate platform icon bundles from a single SVG"
            Manufacturer="Matt Comeione"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252"/>

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of iconsmaker is already installed. Setup will now exit."/>

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1"/>
        <Property Id="DiskPrompt" Value="iconsmaker Installation"/>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder" Name="PFiles">
                <Directory Id="APPLICATIONFOLDER" Name="iconsmaker">

                    <!-- The executable. -->
                    <Component Id="binary" Guid="*" Win64="yes">
                        <File
                            Id="iconsmakerExe"
                            Name="iconsmaker.exe"
                            DiskId="1"
                            Source="$(var.CargoTargetBinDir)\iconsmaker.exe"
                            KeyPath="yes"/>
                    </Component>

                    <!-- License and HTML help, each in its own single-file
                         component so they can use auto-generated GUIDs (a
                         multi-file component with an unversioned keypath cannot
                         — WiX error LGHT0367). -->
                    <Component Id="license" Guid="*" Win64="yes">
                        <File Id="licenseTxt" Name="LICENSE.txt" DiskId="1" Source="LICENSE" KeyPath="yes"/>
                    </Component>

                    <Component Id="htmlDoc" Guid="*" Win64="yes">
                        <File Id="iconsmakerHtml" Name="iconsmaker.html" DiskId="1" Source="target\assets\iconsmaker.html" KeyPath="yes"/>
                    </Component>

                    <!-- Add the install folder to the system PATH. -->
                    <Component Id="path" Guid="B84E2D77-0C3F-49A6-9F1E-7A5D3E9C1B02" Win64="yes">
                        <CreateFolder/>
                        <Environment
                            Id="PATH"
                            Name="PATH"
                            Value="[APPLICATIONFOLDER]"
                            Permanent="no"
                            Part="last"
                            Action="set"
                            System="yes"/>
                    </Component>

                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id="Binaries"
            Title="iconsmaker"
            Description="The iconsmaker command-line tool, documentation, and PATH entry."
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER"
            AllowAdvertise="no"
            Display="expand"
            Absent="disallow">
            <ComponentRef Id="binary"/>
            <ComponentRef Id="license"/>
            <ComponentRef Id="htmlDoc"/>
            <ComponentRef Id="path"/>
        </Feature>

        <SetProperty Id="ARPINSTALLLOCATION" Value="[APPLICATIONFOLDER]" After="CostFinalize"/>
    </Product>
</Wix>